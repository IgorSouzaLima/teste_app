{
  "expo": {
    "name": "Entregas",
    "slug": "entregas-motorista",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#185FA5"
    },
    "android": {
      "package": "com.igorsouzalima.entregas",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "foregroundService": {
        "notificationTitle": "Rastreamento ativo",
        "notificationBody": "Sua localização está sendo compartilhada",
        "notificationColor": "#185FA5"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#185FA5"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O app precisa da sua localização para rastrear a entrega em tempo real.",
          "locationAlwaysPermission": "O app precisa da localização em segundo plano durante a entrega.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "O app precisa da câmera para fotografar o comprovante de entrega."
        }
      ],
      "expo-task-manager"
    ],
    "extra": {
      "eas": {
        "projectId": "a8d40471-ca1c-4e52-bb79-0a9b7f2a831d"
      }
    }
  }
}
